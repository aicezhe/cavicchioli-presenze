rules_version = '2';

// Regole di accesso di Cavicchioli Presenze.
// Il ruolo è salvato in users/{uid}.role; la segregazione tra scuole si basa
// su schools/{schoolId}.adminIds — un admin opera SOLO sulla propria scuola.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Documento-profilo dell'utente corrente
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && myRole() == 'admin';
    }

    // Admin della scuola specifica: uid presente in schools/{schoolId}.adminIds.
    // È questo, non il solo ruolo 'admin', a impedire l'accesso incrociato tra scuole.
    function isSchoolAdmin(schoolId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/schools/$(schoolId)).data.adminIds;
    }

    // Operatore assegnato a una classe specifica
    function isClassOperator(schoolId, classId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)).data.operatorIds;
    }

    // Il genitore è collegato tramite l'email autenticata presente in parentEmails
    function isChildParent(schoolId, classId, childId) {
      return signedIn()
        && request.auth.token.email in get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)/children/$(childId)).data.parentEmails;
    }

    // COLLECTION GROUP: l'operatore trova le PROPRIE classi in qualunque scuola.
    // Le query collectionGroup NON sono autorizzate dal match annidato
    // schools/{id}/classes/{id}: servono un match con wildcard ricorsivo.
    // La condizione è solo su resource.data.operatorIds → la query
    // "operatorIds array-contains uid" è filtrabile e ammessa; ogni altra classe
    // resta inaccessibile anche con una query diretta a Firestore.
    match /{path=**}/classes/{classId} {
      allow read: if signedIn() && request.auth.uid in resource.data.operatorIds;
    }

    // COLLECTION GROUP: il genitore trova i PROPRI figli in qualunque classe/scuola.
    // Condizione solo su resource.data.parentEmails (email autenticata) → query filtrabile.
    match /{path=**}/children/{childId} {
      allow read: if signedIn() && request.auth.token.email in resource.data.parentEmails;
    }

    match /users/{uid} {
      // Ognuno vede il proprio profilo; l'admin vede tutti; i profili OPERATORE sono
      // leggibili da qualsiasi utente autenticato (rubrica contatti per i genitori:
      // nome, email, telefono). Le altre info restano riservate.
      allow read: if signedIn()
        && (request.auth.uid == uid || isAdmin() || resource.data.role == 'operatore');

      // Nessuna auto-registrazione: gli account sono creati dalla scuola (il direttore
      // consegna le credenziali). Profili e ruoli li gestisce solo l'admin.
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /schools/{schoolId} {
      // Lettura via resource.data (NON get sul doc stesso): così la query
      // "adminIds array-contains uid" è filtrabile e le regole la consentono.
      // get() sul documento che si sta elencando non è ammesso nelle query.
      allow read: if signedIn() && request.auth.uid in resource.data.adminIds;
      // Creazione (bootstrap): un admin può creare una scuola solo includendosi in adminIds
      allow create: if isAdmin() && request.auth.uid in request.resource.data.adminIds;
      // Modifica/eliminazione: uid negli adminIds del documento (resource è la scuola)
      allow update, delete: if signedIn() && request.auth.uid in resource.data.adminIds;

      match /classes/{classId} {
        // Admin (get sul doc PADRE, path fisso → ammesso) oppure operatore assegnato
        // (resource.data.operatorIds → filtrabile con array-contains). Entrambi ok nelle query.
        allow read: if isSchoolAdmin(schoolId)
          || (signedIn() && request.auth.uid in resource.data.operatorIds);
        allow create, update, delete: if isSchoolAdmin(schoolId);

        match /children/{childId} {
          // Admin/operatore: get su antenati a path fisso (scuola/classe) → ammesso nelle query.
          // Genitore: email in resource.data.parentEmails → filtrabile.
          allow read: if isSchoolAdmin(schoolId)
            || isClassOperator(schoolId, classId)
            || (signedIn() && request.auth.token.email in resource.data.parentEmails);
          allow create, update, delete: if isSchoolAdmin(schoolId);

          match /attendance/{date} {
            allow read: if isSchoolAdmin(schoolId)
              || isClassOperator(schoolId, classId)
              || isChildParent(schoolId, classId, childId);
            // Registrano la presenza l'operatore della classe e l'admin della scuola;
            // markedBy deve coincidere con l'autore della richiesta
            allow create, update: if (isSchoolAdmin(schoolId) || isClassOperator(schoolId, classId))
              && request.resource.data.markedBy == request.auth.uid;
            allow delete: if false;
          }
        }
      }
    }
  }
}
